# Copie para .env e preencha os valores antes de executar docker compose
# NUNCA commite o arquivo .env no repositório

# ── Ambiente ──────────────────────────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Production

# ── Portas expostas (somente 127.0.0.1) ──────────────────────────────────────
API_HTTP_PORT=5031
MONGO_PORT=27017
MONGO_EXPRESS_PORT=8081

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_ROOT_USERNAME=ats_admin
MONGO_ROOT_PASSWORD=TROQUE_POR_SENHA_FORTE
MONGO_DATABASE_NAME=AtsDb
MONGO_MAX_CONNECTION_POOL_SIZE=100

# ── Mongo Express (perfil: tools) ─────────────────────────────────────────────
MONGO_EXPRESS_USERNAME=express_admin
MONGO_EXPRESS_PASSWORD=TROQUE_POR_SENHA_FORTE

# ── CORS ──────────────────────────────────────────────────────────────────────
# Origens separadas por vírgula. Exemplo: https://meusite.com,https://admin.meusite.com
CORS_ALLOWED_ORIGINS=https://meusite.com

# ── Observability (perfil: observability) ─────────────────────────────────────
JAEGER_UI_PORT=16686
JAEGER_OTLP_PORT=4317
PROMETHEUS_PORT=9090
# Endpoint OTLP para exportar traces/métricas (deixe vazio para desabilitar)
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
OTEL_SERVICE_NAME=ats-api
