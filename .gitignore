# =============================================================================
# .gitignore – ATS (.NET 10 + Rider + VS Code)
# Localização: raiz do repositório
# =============================================================================

# ─── Artefatos de build (NUNCA commitar) ─────────────────────────────────────
[Bb]in/
[Oo]bj/
out/
publish/

# ─── Arquivos de usuário do Visual Studio ────────────────────────────────────
*.user
*.suo
*.userosscache
*.sln.docstates
.vs/

# ─── JetBrains Rider ─────────────────────────────────────────────────────────
.idea/
*.DotSettings.user

# ─── VS Code ─────────────────────────────────────────────────────────────────
.vscode/
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/tasks.json

# ─── Variáveis de ambiente e segredos ────────────────────────────────────────
.env
.env.*
!.env.example
*.pfx
*.p12
secrets.json
appsettings.*.json
!appsettings.json
!appsettings.Development.json

# ─── Pacotes NuGet restaurados localmente ────────────────────────────────────
packages/
*.nupkg
*.snupkg
project.lock.json
project.fragment.lock.json
artifacts/

# ─── Logs e relatórios ───────────────────────────────────────────────────────
*.log
TestResults/
coverage/
coverage-report/
*.trx
*.coverage
*.coveragexml

# ─── Docker ──────────────────────────────────────────────────────────────────
mongo-data/

# ─── macOS ───────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ─── Windows ─────────────────────────────────────────────────────────────────
Thumbs.db
Desktop.ini

# ─── Linux ───────────────────────────────────────────────────────────────────
*~